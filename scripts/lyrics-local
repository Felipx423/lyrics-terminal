#!/usr/bin/env python3

from __future__ import annotations

import argparse
import shlex
import shutil
import subprocess
import sys
import time
from pathlib import Path

import lyricslib as lib


SCRIPT = Path(__file__).resolve()
POLL_INTERVAL_SECONDS = 0.20
PAUSE_POLL_SECONDS = 0.50
EXIT_TRACK_CHANGED = 3


def main() -> int:
    parser = argparse.ArgumentParser(add_help=True)
    parser.add_argument("--run", action="store_true")
    parser.add_argument("--debug", action="store_true")
    parser.add_argument("--file", dest="file_path")
    args = parser.parse_args()

    lib.log_event("startup", {"script": "lyrics-local", "mode": "run" if args.run else "kitty", "debug": args.debug})

    if args.run:
        return run_terminal(debug=args.debug, file_path=args.file_path)
    return launch_kitty(debug=args.debug, file_path=args.file_path)


def launch_kitty(debug: bool = False, file_path: str | None = None) -> int:
    if not shutil.which("kitty"):
        print("lyrics-local: kitty não encontrado no PATH.", file=sys.stderr)
        return 1
    cmd = [
        "kitty",
        "--detach",
        "--override",
        f"font_family={lib.FONT_FAMILY}",
        "--override",
        f"font_size={lib.FONT_SIZE}",
        "--title",
        "Lyrics",
        "bash",
        "-lc",
        f"{shlex.quote(str(SCRIPT))} {' '.join(shlex.quote(flag) for flag in runtime_flags(debug, file_path))}",
    ]
    subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return 0


def runtime_flags(debug: bool, file_path: str | None) -> list[str]:
    flags = ["--run"]
    if debug:
        flags.insert(0, "--debug")
    if file_path:
        flags.extend(["--file", file_path])
    return flags


def run_terminal(debug: bool = False, file_path: str | None = None) -> int:
    lib.DEBUG = debug
    lib.setup_terminal()
    try:
        if file_path:
            path = Path(file_path)
            try:
                text = path.read_text(encoding="utf-8")
            except Exception:
                text = None
            track = lib.get_track_info()
            if not track:
                lib.render_message("No track metadata", ["Não consegui ler os metadados do Spotify."])
                time.sleep(4)
                return 1
            lib.log_event("track_detected", f"{track.artist} - {track.title}")
            if not text:
                lib.log_event("cache_miss", str(path))
                lib.render_message("Lyrics not found", [str(path)])
                time.sleep(4)
                return 0
            reason = lib.local_lrc_invalid_reason(track, text)
            if reason:
                lib.debug_log("local_lrc", f"invalid {reason}")
                lib.log_event("cache_invalid", reason)
                lib.log_event("quarantine", str(path))
                lib.render_message("Invalid .lrc", [str(path)])
                time.sleep(4)
                return 0
            lines, offset_ms = lib.parse_lrc_text(text)
            if not lines:
                lib.render_message("Invalid .lrc", [str(path)])
                time.sleep(4)
                return 0
            lib.debug_log("lrc_path", str(path))
            lib.log_event("cache_hit", str(path))
            return stream_local(track, lines, offset_ms)

        status = lib.spotify_status()
        lib.debug_log("spotify_status", status or "unknown")
        if status != "playing":
            lib.render_message("Spotify not playing", ["Abra o Spotify e inicie uma música."])
            time.sleep(4)
            return 0

        track = lib.get_track_info()
        if not track:
            lib.render_message("No track metadata", ["Não consegui ler os metadados do Spotify."])
            time.sleep(4)
            return 1

        lib.debug_log("track", f"{track.artist} - {track.title}")
        lib.log_event("track_detected", f"{track.artist} - {track.title}")

        path, text, reason = lib.load_local_lrc_text_with_reason(track)
        if not path or not text:
            if reason:
                lib.debug_log("local_lrc", f"invalid {reason}")
                lib.log_event("cache_invalid", reason)
            lib.render_message(
                "Lyrics not found",
                [
                    f"{track.artist} - {track.title}",
                    "",
                    "Nenhum .lrc local correspondente foi encontrado.",
                ],
            )
            time.sleep(4)
            return 0

        lines, offset_ms = lib.parse_lrc_text(text)
        if not lines:
            lib.debug_log("local_lrc", "invalid no_timestamp")
            lib.log_event("cache_invalid", "no_timestamp")
            lib.render_message("Invalid .lrc", [str(path)])
            time.sleep(4)
            return 0

        lib.debug_log("lrc_path", str(path))
        lib.log_event("cache_hit", str(path))
        return stream_local(track, lines, offset_ms)
    finally:
        lib.restore_terminal()


def stream_local(track: lib.TrackInfo, lines: list[tuple[int, str]], offset_ms: int) -> int:
    last_line = ""
    last_size = (0, 0)
    was_paused = False
    while True:
        status = lib.spotify_status()
        if status == "paused":
            if not was_paused:
                lib.debug_log("spotify_paused", track_label(track))
                was_paused = True
            fresh = lib.get_track_info()
            if not fresh or not same_track(fresh, track):
                lib.debug_log("track_changed_while_paused", f"{track_label(track)} -> {track_label(fresh) if fresh else 'unknown'}")
                return EXIT_TRACK_CHANGED
            lib.debug_log("paused_wait", "lyrics-local")
            time.sleep(PAUSE_POLL_SECONDS)
            continue
        if status != "playing":
            break

        if was_paused:
            lib.debug_log("spotify_resumed", track_label(track))
            was_paused = False

        fresh = lib.get_track_info()
        if not fresh:
            break
        if not same_track(fresh, track):
            return EXIT_TRACK_CHANGED

        pos_ms = lib.current_position_ms() + offset_ms
        line = lib.current_line(lines, pos_ms)
        size = shutil.get_terminal_size((80, 24))
        size_tuple = (size.columns, size.lines)

        if line != last_line or size_tuple != last_size:
            lib.render_single_line(line)
            last_line = line
            last_size = size_tuple

        time.sleep(POLL_INTERVAL_SECONDS)

    return 0


def track_label(track: lib.TrackInfo | None) -> str:
    if not track:
        return "unknown"
    return f"{track.artist} - {track.title}"


def same_track(a: lib.TrackInfo, b: lib.TrackInfo) -> bool:
    return lib.normalize_text(track_label(a)) == lib.normalize_text(track_label(b))


if __name__ == "__main__":
    raise SystemExit(main())

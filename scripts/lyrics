#!/usr/bin/env python3

from __future__ import annotations

import argparse
import shlex
import shutil
import subprocess
import sys
import time
from pathlib import Path

import lyricslib as lib


SCRIPT = Path(__file__).resolve()
FETCH_GO_SCRIPT = SCRIPT.with_name("lyrics-fetch-go")
POLL_INTERVAL_SECONDS = 0.20
LOCAL_LRC_POLL_SECONDS = 2.0
DEFAULT_NO_OUTPUT_SECONDS = 10.0
EXIT_TRACK_CHANGED = 3


def main() -> int:
    parser = argparse.ArgumentParser(add_help=True)
    parser.add_argument("--run", action="store_true")
    parser.add_argument("--debug", action="store_true")
    parser.add_argument("--no-output-timeout", type=float, default=DEFAULT_NO_OUTPUT_SECONDS)
    args = parser.parse_args()

    if args.run:
        return run_terminal(debug=args.debug, no_output_timeout=args.no_output_timeout)
    return launch_kitty(debug=args.debug)


def launch_kitty(debug: bool = False) -> int:
    missing = [name for name in ("kitty", "playerctl", "python3") if not shutil.which(name)]
    if missing:
        print("lyrics: faltam dependências:", file=sys.stderr)
        for name in missing:
            print(f"  - {name}", file=sys.stderr)
        return 1

    cmd = [
        "kitty",
        "--detach",
        "--override",
        f"font_family={lib.FONT_FAMILY}",
        "--override",
        f"font_size={lib.FONT_SIZE}",
        "--title",
        "Lyrics",
        "bash",
        "-lc",
        f"{shlex.quote(str(SCRIPT))} {' '.join(shlex.quote(flag) for flag in runtime_flags(debug))}",
    ]
    subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return 0


def runtime_flags(debug: bool) -> list[str]:
    flags = ["--run"]
    if debug:
        flags.insert(0, "--debug")
    return flags


def run_terminal(debug: bool = False, no_output_timeout: float = DEFAULT_NO_OUTPUT_SECONDS) -> int:
    lib.DEBUG = debug
    lib.setup_terminal()
    try:
        missing = [name for name in ("playerctl", "python3") if not shutil.which(name)]
        if missing:
            lib.render_message("Dependencies missing", ["Instale:", *[f"- {name}" for name in missing]])
            return 1

        if debug:
            lib.debug_log("no_output_timeout", f"{format_seconds(no_output_timeout)}s")

        last_track_key: str | None = None
        last_track_label = ""
        fetch_spawned_for_key: str | None = None
        outer_was_paused = False

        started = False
        while True:
            status = lib.spotify_status()
            lib.debug_log("spotify_status", status or "unknown")
            if status == "paused":
                if not outer_was_paused:
                    lib.debug_log("spotify_paused", "lyrics")
                    outer_was_paused = True
                time.sleep(POLL_INTERVAL_SECONDS)
                continue
            if outer_was_paused and status == "playing":
                lib.debug_log("spotify_resumed", "lyrics")
                outer_was_paused = False
            if status != "playing":
                if not started:
                    lib.render_message(
                        "Spotify not playing",
                        [
                            "Abra o Spotify e inicie uma música.",
                            "Depois rode `lyrics` de novo.",
                        ],
                    )
                else:
                    lib.debug_log("playback", "stopped")
                return 0

            track = lib.get_track_info()
            if not track:
                lib.render_message("No track metadata", ["Não consegui ler os metadados do Spotify."])
                return 1

            started = True
            current_key = track_signature(track)
            current_label = track_label(track)

            if last_track_key and current_key != last_track_key:
                lib.clear_screen()
                lib.debug_log("track_changed", f"{last_track_label} -> {current_label}")
                lib.debug_log("pipeline_restart", "restarting_pipeline")
                fetch_spawned_for_key = None

            lib.debug_log("pipeline_start", "starting")
            lib.debug_log("current_track", current_label)

            local_path = lib.find_local_lrc(track)
            if local_path:
                lib.debug_log("local_lrc", f"found {local_path}")
            else:
                lib.debug_log("local_lrc", "missing")

            if local_path:
                last_track_key = current_key
                last_track_label = current_label
                exit_code = exec_lyrics_local(debug=debug)
                if exit_code == EXIT_TRACK_CHANGED:
                    fresh = lib.get_track_info()
                    next_label = track_label(fresh) if fresh else "unknown"
                    lib.clear_screen()
                    lib.debug_log("track_changed", f"{current_label} -> {next_label}")
                    lib.debug_log("pipeline_restart", "restarting_pipeline")
                    last_track_key = track_signature(fresh) if fresh else None
                    last_track_label = next_label
                    fetch_spawned_for_key = None
                    continue
            else:
                if fetch_spawned_for_key != current_key:
                    if spawn_background_fetch(track, debug=debug) is not None:
                        fetch_spawned_for_key = current_key
                stream_status, next_track = stream_sptlrx(track, no_output_timeout=no_output_timeout)

                if stream_status == "track_changed":
                    lib.clear_screen()
                    next_label = track_label(next_track) if next_track else "unknown"
                    lib.debug_log("track_changed", f"{current_label} -> {next_label}")
                    lib.debug_log("pipeline_restart", "restarting_pipeline")
                    last_track_key = track_signature(next_track) if next_track else None
                    last_track_label = next_label
                    fetch_spawned_for_key = None
                    continue

                if stream_status == "no_output":
                    wait_status, wait_track = wait_for_local_lrc_or_track_change(track)
                    if wait_status == "track_changed":
                        lib.clear_screen()
                        next_label = track_label(wait_track) if wait_track else "unknown"
                        lib.debug_log("track_changed", f"{current_label} -> {next_label}")
                        lib.debug_log("pipeline_restart", "restarting_pipeline")
                        last_track_key = track_signature(wait_track) if wait_track else None
                        last_track_label = next_label
                        fetch_spawned_for_key = None
                        continue
                    if wait_status == "local_ready":
                        lib.clear_screen()
                        lib.debug_log("pipeline_restart", "restarting_pipeline")
                        continue
                    if wait_status == "stopped":
                        return 0
                    return 1

                if stream_status == "stopped":
                    lib.debug_log("pipeline_restart", "restarting_pipeline")
                    last_track_key = current_key
                    last_track_label = current_label
                    continue

                return 1

            last_track_key = current_key
            last_track_label = current_label
            time.sleep(POLL_INTERVAL_SECONDS)
    finally:
        lib.restore_terminal()


def exec_lyrics_local(debug: bool = False) -> int:
    cmd = [sys.executable, str(Path(__file__).with_name("lyrics-local"))]
    if debug:
        cmd.append("--debug")
    cmd.append("--run")
    lib.debug_log("lyrics_local", {"cmd": cmd})
    return subprocess.call(cmd)


def track_label(track: lib.TrackInfo) -> str:
    return f"{track.artist} - {track.title}"


def track_signature(track: lib.TrackInfo) -> str:
    return lib.normalize_text(track_label(track))


def spawn_background_fetch(track: lib.TrackInfo, debug: bool = False) -> int | None:
    if not FETCH_GO_SCRIPT.exists():
        lib.debug_log("fetch_spawn_failed", "lyrics-fetch-go missing")
        return None
    cmd = [str(FETCH_GO_SCRIPT), "--no-spotify", "--artist", track.artist, "--title", track.title]
    if track.album:
        cmd.extend(["--album", track.album])
    if track.duration_ms:
        cmd.extend(["--duration", str(max(0, int(track.duration_ms / 1000)))])
    if track.track_id:
        cmd.extend(["--track-id", track.track_id])
    if debug:
        cmd.append("--debug")
    try:
        proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        lib.debug_log("fetch_spawned", f"pid={proc.pid} cmd={cmd}")
        return proc.pid
    except Exception as exc:
        lib.debug_log("fetch_spawn_failed", exc)
        return None


def stream_sptlrx(track: lib.TrackInfo, no_output_timeout: float = DEFAULT_NO_OUTPUT_SECONDS) -> tuple[str, lib.TrackInfo | None]:
    if not shutil.which("sptlrx"):
        lib.render_message(
            "sptlrx missing",
            [
                "Instale `sptlrx` para ver letras sincronizadas.",
                "O fetch automático continua em background.",
            ],
        )
        return "no_output", None

    lib.debug_log("sptlrx_start", track_label(track))
    proc = subprocess.Popen(
        ["sptlrx", "pipe"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        bufsize=1,
    )
    try:
        return stream_sptlrx_lines(proc, track, no_output_timeout=no_output_timeout)
    finally:
        lib.terminate_process(proc)


def stream_sptlrx_lines(
    proc: subprocess.Popen[str],
    track: lib.TrackInfo,
    no_output_timeout: float = DEFAULT_NO_OUTPUT_SECONDS,
) -> tuple[str, lib.TrackInfo | None]:
    if proc.stdout is None:
        return "no_output", None
    last_line = ""
    last_status = ""
    start_at = time.monotonic()
    output_seen = False
    was_paused = False
    while True:
        status = lib.spotify_status()
        if status == "paused":
            if not was_paused:
                lib.debug_log("spotify_paused", track_label(track))
                was_paused = True
            lib.debug_log("paused_wait", "sptlrx")
            fresh = lib.get_track_info()
            if fresh and track_signature(fresh) != track_signature(track):
                lib.debug_log("track_changed_while_paused", f"{track_label(track)} -> {track_label(fresh)}")
                return "track_changed", fresh
            time.sleep(POLL_INTERVAL_SECONDS)
            continue

        if was_paused and status == "playing":
            lib.debug_log("spotify_resumed", track_label(track))
            was_paused = False

        if status != "playing":
            return "stopped", None

        fresh = lib.get_track_info()
        if not fresh:
            return "stopped", None
        if track_signature(fresh) != track_signature(track):
            return "track_changed", fresh

        line = read_line(proc, timeout=0.4)
        if line is None:
            if proc.poll() is not None:
                if output_seen:
                    return "stopped", None
                lib.render_message(
                    "Buscando letra...",
                    [
                        "Aguardando sptlrx ou cache local.",
                    ],
                )
                lib.debug_log("sptlrx_no_output", "proc_exited_without_output")
                return "no_output", None
            if status != last_status:
                lib.debug_log("sptlrx_status", status)
                last_status = status
            if not output_seen and time.monotonic() - start_at >= no_output_timeout:
                lib.render_message(
                    "Buscando letra...",
                    [
                        "Aguardando sptlrx ou cache local.",
                    ],
                )
                lib.debug_log("sptlrx_no_output", f"{format_seconds(no_output_timeout)}s_without_output")
                return "no_output", None
            continue

        text = line.strip()
        if not lib.is_useful_lyric_line(text) or text == last_line:
            continue
        lib.render_single_line(text)
        last_line = text
        output_seen = True
        start_at = time.monotonic()


def wait_for_local_lrc_or_track_change(track: lib.TrackInfo) -> tuple[str, lib.TrackInfo | None]:
    while True:
        status = lib.spotify_status()
        if status != "playing":
            return "stopped", None

        fresh = lib.get_track_info()
        if not fresh:
            return "stopped", None

        if track_signature(fresh) != track_signature(track):
            return "track_changed", fresh

        if lib.find_local_lrc(track):
            lib.debug_log("local_lrc", "appeared")
            return "local_ready", fresh

        time.sleep(LOCAL_LRC_POLL_SECONDS)


def format_seconds(value: float) -> str:
    if value.is_integer():
        return str(int(value))
    return f"{value:g}"


def read_line(proc: subprocess.Popen[str], timeout: float) -> str | None:
    if proc.stdout is None:
        return None
    try:
        import select

        readable, _, _ = select.select([proc.stdout], [], [], timeout)
        if not readable:
            return None
        line = proc.stdout.readline()
        if line == "":
            return None
        return line
    except Exception:
        return None


if __name__ == "__main__":
    raise SystemExit(main())
